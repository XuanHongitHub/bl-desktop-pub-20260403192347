{
  "name": "buglogin",
  "private": true,
  "license": "AGPL-3.0",
  "version": "0.17.0",
  "type": "module",
  "scripts": {
    "guard:runtime": "node scripts/guard-node-modules-runtime.mjs",
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack -p 12341",
    "dev:webpack": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack -p 12341",
    "build": "next build",
    "start": "next start",
    "test": "pnpm test:rust:unit && pnpm test:sync-e2e",
    "test:rust": "cd src-tauri && cargo test",
    "test:rust:unit": "cd src-tauri && cargo test --lib && cargo test --test buglogin_proxy_integration",
    "test:sync-e2e": "node scripts/sync-test-harness.mjs",
    "lint": "pnpm lint:js && pnpm lint:rust",
    "lint:js": "biome check src/ && tsc --noEmit && node scripts/audit-ui-consistency.mjs && node scripts/run-in-sync-dir.mjs \"biome check src/ && tsc --noEmit\"",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings -D clippy::all && cargo fmt --all",
    "tauri": "pnpm exec tauri",
    "shadcn:add": "pnpm dlx shadcn@latest add",
    "prepare": "husky && husky install",
    "format:rust": "cd src-tauri && cargo clippy --fix --allow-dirty --all-targets --all-features -- -D warnings -D clippy::all && cargo fmt --all",
    "format:js": "biome check src/ --write --unsafe && node scripts/run-in-sync-dir.mjs \"biome check src/ --write --unsafe\"",
    "format": "pnpm format:js && pnpm format:rust",
    "build:sync": "node scripts/run-in-sync-dir.mjs \"pnpm build\"",
    "cargo": "cd src-tauri && cargo",
    "unused-exports:js": "ts-unused-exports tsconfig.json",
    "check-unused-commands": "cd src-tauri && cargo test test_no_unused_tauri_commands",
    "copy-proxy-binary": "node src-tauri/copy-proxy-binary.mjs",
    "prebuild": "pnpm copy-proxy-binary",
    "audit:ui": "node scripts/audit-ui-consistency.mjs",
    "sync:portal-home": "node scripts/sync-portal-home-fixtures.mjs",
    "smoke:control-sync": "node scripts/smoke-control-sync-subscription.mjs",
    "predev": "pnpm guard:runtime",
    "preformat": "pnpm guard:runtime",
    "prelint": "pnpm guard:runtime",
    "pretest": "pnpm guard:runtime",
    "pretauri": "node scripts/guard-node-modules-runtime.mjs",
    "pretauri:dev": "node scripts/guard-node-modules-runtime.mjs",
    "precargo": "pnpm copy-proxy-binary"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "ahooks": "^3.9.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "flag-icons": "^7.5.0",
    "geist": "^1.7.0",
    "i18next": "^25.8.13",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.3",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^4.8.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tauri-plugin-macos-permissions-api": "^2.3.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "~2.10.0",
    "@types/color": "^4.2.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "playwright": "1.54.2",
    "tailwindcss": "^4.2.1",
    "ts-unused-exports": "^11.0.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css}": [
      "biome check --fix"
    ],
    "src-tauri/**/*.rs": [
      "bash -c 'cd src-tauri && cargo fmt --all'",
      "bash -c 'cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings -D clippy::all'",
      "bash -c 'cd src-tauri && cargo test --lib'"
    ]
  }
}
