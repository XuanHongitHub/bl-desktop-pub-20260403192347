
APPLE_TEAM_ID=
APPLE_ID=
APPLE_PASSWORD=
APPLE_SIGNING_IDENTITY=

# Runtime overrides used by Tauri backend in local dev.
# Loaded from .env/.env.local and forwarded by scripts/tauri-before-dev.mjs.
BUGLOGIN_AUTH_API_URL=
BUGLOGIN_STRIPE_PUBLISHABLE_KEY=
BUGLOGIN_STRIPE_BILLING_URL=
# Canonical web portal base URL (pricing/billing/admin web pages).
NEXT_PUBLIC_WEB_PORTAL_URL=
# Legacy aliases still supported for backward compatibility.
NEXT_PUBLIC_BILLING_PORTAL_URL=
NEXT_PUBLIC_STRIPE_BILLING_URL=
NEXT_PUBLIC_SYNC_SERVER_URL=
NEXT_PUBLIC_SYNC_TOKEN=

# Automation output sink (admin-only settings fallback).
BUGLOGIN_AUTOMATION_OUTPUT_ENABLED=false
BUGLOGIN_AUTOMATION_OUTPUT_DIR=
BUGLOGIN_AUTOMATION_DRIVE_FOLDER_ID=
BUGLOGIN_AUTOMATION_DRIVE_OAUTH_CLIENT=
BUGLOGIN_AUTOMATION_DRIVE_OAUTH_REFRESH=

# TikTok Seller automation defaults
BUGLOGIN_WORKFLOW_CAPTCHA_DEFAULT_KEY=""
NEXT_PUBLIC_WORKFLOW_CAPTCHA_DEFAULT_KEY=""
NEXT_PUBLIC_OMOCAPTCHA_XPI_PATH="D:\\Download\\omocaptcha_auto_solve_captcha-1.6.9.xpi"
